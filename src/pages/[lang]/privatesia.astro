---
import Base from "../../layouts/Base.astro";
import { languages, type Lang } from "../../i18n/index";
import { t } from "../../i18n/translations";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const tr = t(lang);
const legal = tr.legal;
---

<Base lang={lang} title={legal.privacy.title} description={legal.privacy.subtitle}>
  <section class="bg-brand-green-light border-b border-surface-border">
    <div class="max-w-content mx-auto px-5 lg:px-8 py-12 md:py-16">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-4xl font-extrabold text-brand-green mb-3 font-display">{legal.privacy.title}</h1>
        <p class="text-base md:text-lg text-txt-secondary">{legal.privacy.subtitle}</p>
        <p class="text-sm text-txt-muted mt-4">{legal.lastUpdated}</p>
      </div>
    </div>
  </section>

  <section>
    <div class="max-w-3xl mx-auto px-5 lg:px-8 py-10 md:py-14">
      <div class="flex flex-col gap-7">
        {legal.privacy.sections.map((s) => (
          <div>
            <h2 class="text-lg md:text-xl font-bold text-txt-primary mb-2">{s.h}</h2>
            <p class="text-sm md:text-base text-txt-secondary leading-relaxed">{s.p}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 pt-8 border-t border-surface-border flex flex-wrap items-center gap-4 text-sm">
        <a href={`/${lang}`} class="text-brand-green hover:underline font-semibold">&larr; {legal.backHome}</a>
        <span class="text-txt-muted">|</span>
        <a href={`/${lang}/cookies`} class="text-brand-green hover:underline">{legal.cookiesLink}</a>
      </div>
    </div>
  </section>
</Base>
