---
import type { Lang } from "../i18n/index";
import { t } from "../i18n/translations";
import SafeExit from "./SafeExit.astro";
import LangSwitcher from "./LangSwitcher.astro";

interface Props {
  currentPath: string;
  lang: Lang;
}

const { currentPath, lang } = Astro.props;
const tr = t(lang);

const navItems = [
  { href: `/${lang}/hapat`, label: tr.nav.guide, match: /\/hapat/ },
  { href: `/${lang}/dokumento`, label: tr.nav.doc, match: /\/dokumento/ },
  { href: `/${lang}/ndihme`, label: tr.nav.resources, match: /\/ndihme/ },
  { href: `/${lang}/thirr`, label: tr.nav.hotlines, match: /\/thirr/ },
  { href: `/${lang}/siguria`, label: tr.nav.safety, match: /\/siguria/ },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-surface-border">
  <nav class="max-w-content mx-auto px-5 lg:px-8 flex items-center justify-between h-16">
    <div class="flex items-center gap-8">
      <a href={`/${lang}`} class="flex items-center gap-2.5 no-underline text-brand-green font-bold text-lg">
        <span class="w-3 h-3 rounded-full bg-brand-green"></span>
        Informata
      </a>
      <div class="hidden md:flex items-center gap-1">
        {navItems.map((item) => {
          const active = item.match.test(currentPath);
          return (
            <a
              href={item.href}
              class:list={[
                "px-4 py-2 rounded-lg text-sm font-medium no-underline transition-colors",
                active
                  ? "bg-brand-green-light text-brand-green font-semibold"
                  : "text-txt-secondary hover:text-txt-primary hover:bg-surface-card",
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </div>
    </div>
    <div class="flex items-center gap-3">
      <div class="hidden sm:block">
        <LangSwitcher lang={lang} currentPath={currentPath} />
      </div>
      <SafeExit label={tr.exit} />
    </div>
  </nav>
</header>
