---
import "../styles/global.css";
import TopNav from "../components/TopNav.astro";
import BottomNav from "../components/BottomNav.astro";
import EmergencyBanner from "../components/EmergencyBanner.astro";
import PrivacyBanner from "../components/PrivacyBanner.astro";
import { languages, type Lang } from "../i18n/index";
import { t } from "../i18n/translations";

interface Props {
  title?: string;
  description?: string;
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const title = Astro.props.title || tr.meta.title;
const description = Astro.props.description || tr.meta.description;
const currentPath = Astro.url.pathname;

const site = Astro.site ?? new URL("https://mira.mk");
const canonical = new URL(currentPath, site).toString();

// Strip the leading lang segment so we can build alternates for every language.
const pathWithoutLang = (() => {
  const parts = currentPath.split("/").filter(Boolean);
  if (parts[0] && parts[0] in languages) parts.shift();
  return parts.length ? "/" + parts.join("/") : "/";
})();

const localeMap: Record<Lang, string> = {
  mk: "mk-MK",
  sq: "sq-AL",
  en: "en-US",
  tr: "tr-TR",
  bcms: "bs-BA",
  rom: "rom",
};

const alternateRel = (l: Lang) =>
  pathWithoutLang === "/" ? `/${l}/` : `/${l}${pathWithoutLang}/`;

const alternates = (Object.keys(languages) as Lang[]).map((l) => ({
  hreflang: localeMap[l],
  href: new URL(alternateRel(l), site).toString(),
}));

const ogLocaleAlternates = alternates
  .filter((a) => a.hreflang !== localeMap[lang])
  .map((a) => a.hreflang.replace("-", "_"));

const isHome = pathWithoutLang === "/";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": new URL("/#organization", site).toString(),
      name: "Mira",
      url: site.toString(),
      logo: new URL("/og.png", site).toString(),
      areaServed: { "@type": "Country", name: "North Macedonia" },
    },
    {
      "@type": "WebSite",
      "@id": new URL("/#website", site).toString(),
      url: site.toString(),
      name: "Mira",
      description: tr.meta.description,
      inLanguage: localeMap[lang],
      publisher: { "@id": new URL("/#organization", site).toString() },
    },
    ...(isHome
      ? [
          {
            "@type": "WebPage",
            "@id": canonical,
            url: canonical,
            name: title,
            description,
            inLanguage: localeMap[lang],
            isPartOf: { "@id": new URL("/#website", site).toString() },
          },
        ]
      : []),
  ],
};
---

<!doctype html>
<html lang={lang === "rom" ? "rom" : lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(alternateRel("mk"), site).toString()}
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mira" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={localeMap[lang].replace("-", "_")} />
    {ogLocaleAlternates.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}
    <meta property="og:image" content={new URL(`/og-${lang}.png`, site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(`/og-${lang}.png`, site).toString()} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- 100% privacy-first analytics -->
    <script data-collect-dnt="true" async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  </head>
  <body class="font-sans bg-white text-txt-primary">
    <EmergencyBanner
      label={tr.home.emergencyLabel}
      actionLabel={tr.home.emergencyAction}
      number="192"
    />
    <TopNav currentPath={currentPath} lang={lang} />
    <main class="pb-20 md:pb-0">
      <slot />
    </main>
    <footer class="border-t border-surface-border bg-white pb-20 md:pb-0">
      <div class="max-w-content mx-auto px-5 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
        <div class="text-brand-green font-extrabold tracking-tight font-display">
          mira<span class="text-brand-green/40">.</span>
        </div>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-txt-muted">
          <a href={`/${lang}/privatesia`} class="hover:text-brand-green transition-colors">{tr.legal.privacyLink}</a>
          <span class="opacity-40">·</span>
          <a href={`/${lang}/cookies`} class="hover:text-brand-green transition-colors">{tr.legal.cookiesLink}</a>
          <span class="opacity-40">·</span>
          <a href={`/${lang}/kontribuo`} class="hover:text-brand-green transition-colors">{tr.home.providerCTA}</a>
        </div>
      </div>
    </footer>
    <BottomNav currentPath={currentPath} lang={lang} />
    <PrivacyBanner lang={lang} />
  </body>
</html>
